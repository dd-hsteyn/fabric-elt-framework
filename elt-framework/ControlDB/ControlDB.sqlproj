<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="0.2.0-preview" />
  <PropertyGroup>
    <Name>ControlDB</Name>
    <ProjectGuid>{b4521477-9a6c-4ebc-a067-02ee9f0b9978}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033,CI</ModelCollation>
    <DefaultSchema>dbo</DefaultSchema>
    <DefaultCollation>Latin1_General_100_BIN2_UTF8</DefaultCollation>
  </PropertyGroup>
  <ItemGroup>
    <!-- SDK auto-discovers all .sql files; exclude pre/post deploy folders from Build -->
    <Build Remove="Pre Deployment Script\**\*.sql" />
    <Build Remove="Post Deployment Script\**\*.sql" />
    <!-- Fabric DW does not support PRIMARY KEY or FOREIGN KEY constraints -->
    <Build Remove="ELT\Keys\PK_*.sql" />
    <Build Remove="ELT\Keys\FK_*.sql" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Pre Deployment Script\DBRoles.PreDeployment.sql" />
    <None Include="Pre Deployment Script\Script.PreDeployment.sql" />
    <None Include="Post Deployment Script\datasources\**\*.sql" />
  </ItemGroup>
  <ItemGroup>
    <PostDeploy Include="Post Deployment Script\Script.PostDeployment.sql">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </PostDeploy>
  </ItemGroup>

</Project>